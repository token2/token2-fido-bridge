# Drop-in for an EXISTING install (Python or C++) already advertising 349e:0010.
# Copy to /etc/udev/rules.d/69-fido2-bridge-snap.rules, then:
#   sudo udevadm control --reload-rules && sudo systemctl restart token2-fido-bridge
SUBSYSTEM=="hidraw", KERNEL=="hidraw*", ENV{HID_ID}=="0003:0000349E:00000001", TAG+="snap_firefox_firefox", TAG+="snap_firefox_geckodriver", TAG+="uaccess"
