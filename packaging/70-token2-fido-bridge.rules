# Ensure /dev/uhid is usable by the bridge (root by default; loosen if needed).
KERNEL=="uhid", TAG+="systemd"

# Tag the virtual UHID FIDO device (Token2 349e:0010) so a snap-confined
# Firefox can open it. UHID devices have no USB parent, so the snap's stock
# ATTRS{idVendor} rule never matches — we match the kernel HID_ID instead.
# HID_ID format is bus:VVVVVVVV:PPPPPPPP in uppercase hex; USB bus = 0003.
SUBSYSTEM=="hidraw", KERNEL=="hidraw*", ENV{HID_ID}=="0003:0000349E:00000001", TAG+="snap_firefox_firefox", TAG+="snap_firefox_geckodriver", TAG+="uaccess"
